# EP-Testing-Tool Konfiguration
# Kopiere diese Datei nach .env und passe die Werte an

# Standard-Umgebung (dev, staging, prod)
DEFAULT_ENV=dev

# Browser-Einstellungen
HEADLESS=true
SLOW_MO=0
BROWSER=chromium

# Timeouts (in Millisekunden)
NAVIGATION_TIMEOUT=30000
RESPONSE_TIMEOUT=10000

# Report-Einstellungen
TESTER_NAME=PO Team

# Login-Credentials (optional, fuer authentifizierte Chatbots)
# CHATBOT_LOGIN_URL=https://stage.ecki.ai/login
# CHATBOT_USERNAME=testuser
# CHATBOT_PASSWORD=
